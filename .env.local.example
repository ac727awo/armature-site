# Sanity CMS
# Get these from https://sanity.io/manage after creating your project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (for server-side data fetching — optional until pages are wired to Sanity)
# Create at https://sanity.io/manage → your project → API → Tokens
# Use "Editor" or "Viewer" permissions depending on use case
SANITY_API_TOKEN=your_token_here

# Resend (existing — already configured)
RESEND_API_KEY=your_resend_key_here
